# SMTP server settings
# If you don't provide SMTP settings, the app will create an Ethereal
# test account at runtime (for local development) and log a preview URL.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=portfolio@example.com
CONTACT_TO_EMAIL=Shaquilleboeja21@gmail.com

# Server port
PORT=3000

# Database (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=portfolio

# JWT secret for auth
JWT_SECRET=your_jwt_secret
